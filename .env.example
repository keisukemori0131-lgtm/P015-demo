# ペラペラスタジオ — 環境変数の見本（Vite は読まない。運用者向け）
# 正規名は CLAUDE.md「環境変数命名規則」に厳守。

# ── サイト共通 ──
VITE_SITE_URL=https://peraperakidscollege.jp   # ★確定ドメインに必ず差し替える（canonical/OG/sitemap の基点）
VITE_SITE_PUBLIC=1
VITE_OG_IMAGE_URL=https://peraperakidscollege.jp/og-image.svg
# VITE_BASE=/                         # Cloudflare ルート配信は未設定で /

# ── UpNote 公開API（パターン B 直叩き・セット 1） ──
VITE_UPNOTE_API_BASE_URL=https://api.upnote.jp
VITE_UPNOTE_PUBLIC_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_UPNOTE_API_KEY_HEADER=X-API-Key

# ── 問い合わせ（Googleフォーム埋め込み） ──
# Googleフォームの「送信」→「< >」埋め込みコードの src（embedded=true 付き URL）を入れる。
VITE_GOOGLE_FORM_EMBED_URL=https://docs.google.com/forms/d/e/xxxxxxxxxxxx/viewform?embedded=true

# ── アクセス解析（任意） ──
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── 旧サイトからの SEO 引き継ぎ（R11） ──
# VITE_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxx
